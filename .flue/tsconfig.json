{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "agents/**/*.ts",
    "lib/**/*.ts",
    "roles/**/*.ts",
    "tests/**/*.ts",
    "workflows/**/*.ts"
  ],
  "exclude": ["dist"]
}
